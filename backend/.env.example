# Copy to .env and fill in your values

# Required in production — generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-to-a-random-secret-key
DATABASE_URL=sqlite:///./azmart.db
ACCESS_TOKEN_EXPIRE_MINUTES=1440
ALGORITHM=HS256

# Comma-separated list of frontend origins allowed to call this API
FRONTEND_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Public demo admin password (this is a demo app — visitors are meant to
# log in as admin, so this isn't a secret; just keep it out of git history
# by rotating it here rather than in seed.py's source)
DEMO_ADMIN_PASSWORD=Admin@123

# Gemini API key for the AI product chatbot (free tier: aistudio.google.com/apikey)
GEMINI_API_KEY=
GEMINI_MODEL=gemini-flash-latest

# Email notifications (optional — leave blank to disable)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SELLER_EMAIL=
